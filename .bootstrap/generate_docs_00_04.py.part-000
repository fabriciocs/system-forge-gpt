webcss = '''/* System Forge Enterprise design tokens */
:root {
  color-scheme: light dark;
  --sf-primary: #005b96; --sf-on-primary: #ffffff; --sf-secondary: #006c67; --sf-tertiary: #8b4a00;
  --sf-background: #f7f9fc; --sf-surface: #ffffff; --sf-surface-variant: #f1f4f8; --sf-on-surface: #18202a;
  --sf-outline: #707984; --sf-error: #ba1a1a; --sf-success: #176b3a;
  --sf-radius-sm: 8px; --sf-radius-md: 12px; --sf-radius-lg: 16px; --sf-radius-xl: 24px;
  --sf-space-1: 4px; --sf-space-2: 8px; --sf-space-3: 12px; --sf-space-4: 16px; --sf-space-6: 24px; --sf-space-8: 32px;
  --sf-motion-fast: 120ms; --sf-motion-short: 180ms; --sf-motion-medium: 240ms;
  --sf-font-sans: Inter, "Segoe UI", Roboto, Arial, sans-serif;
  --sf-font-mono: "JetBrains Mono", "Cascadia Code", Consolas, monospace;
}
[data-theme="dark"] {
  --sf-primary: #62b5f5; --sf-on-primary: #003154; --sf-secondary: #5fd6ce; --sf-tertiary: #ffb86a;
  --sf-background: #0c1117; --sf-surface: #151c24; --sf-surface-variant: #1d2630; --sf-on-surface: #e3e8ef;
  --sf-outline: #89929d; --sf-error: #ffb4ab; --sf-success: #77da95;
}
@media (prefers-color-scheme: dark) { :root:not([data-theme="light"]) {
  --sf-primary: #62b5f5; --sf-on-primary: #003154; --sf-secondary: #5fd6ce; --sf-tertiary: #ffb86a;
  --sf-background: #0c1117; --sf-surface: #151c24; --sf-surface-variant: #1d2630; --sf-on-surface: #e3e8ef;
  --sf-outline: #89929d; --sf-error: #ffb4ab; --sf-success: #77da95;
}}
* { box-sizing: border-box; }
:focus-visible { outline: 2px solid var(--sf-primary); outline-offset: 2px; }
@media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: .001ms !important; transition-duration: .001ms !important; scroll-behavior: auto !important; } }
'''
(THEME / 'web.css').write_text(webcss, encoding='utf-8')

theme_tsx = '''import { createTheme, responsiveFontSizes, type ThemeOptions } from '@mui/material/styles';

export type ForgeThemeMode = 'light' | 'dark';

const shared: ThemeOptions = {
  typography: {
    fontFamily: 'Inter, "Segoe UI", Roboto, Arial, sans-serif',
    h1: { fontWeight: 700, letterSpacing: '-0.03em' },
    h2: { fontWeight: 700, letterSpacing: '-0.02em' },
    h3: { fontWeight: 650 },
    button: { fontWeight: 650, textTransform: 'none' },
  },
  shape: { borderRadius: 12 },
  components: {
    MuiButton: { styleOverrides: { root: { minHeight: 44, borderRadius: 999 } } },
    MuiCard: { styleOverrides: { root: { borderRadius: 16, backgroundImage: 'none' } } },
    MuiFocusVisible: { defaultProps: { className: 'Mui-focusVisible' } },
  },
};

export function createForgeTheme(mode: ForgeThemeMode) {
  const dark = mode === 'dark';
  return responsiveFontSizes(createTheme({
    ...shared,
    palette: {
      mode,
      primary: { main: dark ? '#62B5F5' : '#005B96' },
      secondary: { main: dark ? '#5FD6CE' : '#006C67' },
      warning: { main: dark ? '#FFB86A' : '#8B4A00' },
      error: { main: dark ? '#FFB4AB' : '#BA1A1A' },
      success: { main: dark ? '#77DA95' : '#176B3A' },
      background: { default: dark ? '#0C1117' : '#F7F9FC', paper: dark ? '#151C24' : '#FFFFFF' },
      text: { primary: dark ? '#E3E8EF' : '#18202A', secondary: dark ? '#B8C0CA' : '#4D5661' },
      divider: dark ? '#303944' : '#D8DEE6',
    },
  }));
}

export const lightTheme = createForgeTheme('light');
export const darkTheme = createForgeTheme('dark');
export default lightTheme;
'''
(THEME / 'theme.tsx').write_text(theme_tsx, encoding='utf-8')

# Visual assets
brand_guidelines = '''# Brand guidelines — System Forge Enterprise

## Símbolo

Hexágono estrutural, trilha ascendente e núcleo de IA. Área de proteção mínima igual à largura do núcleo central. Tamanho mínimo: 16 px para símbolo e 120 px para assinatura horizontal.

## Usos permitidos

