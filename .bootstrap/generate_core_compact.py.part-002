(VI/'brand-guidelines.md').write_text('# Brand guidelines\n\nSímbolo hexagonal, trilha ascendente e núcleo âmbar. Área de proteção igual ao núcleo; mínimo 16 px para símbolo e 120 px para assinatura. Não distorcer, rotacionar, recolorir fora da paleta ou aplicar efeitos. Contraste AA e alt text contextual.\n',encoding='utf-8')

def svg(dark=False,word=True):
 bg='#0C1117' if dark else 'none'; p='#62B5F5' if dark else '#005B96'; a='#FFB86A' if dark else '#8B4A00'; t='#E3E8EF' if dark else '#18202A'; w=720 if word else 256; h=180 if word else 256; cx=90 if word else 128; cy=90 if word else 128; r=58 if word else 82
 pts=[]
 for i in range(6):
  ang=math.radians(30+60*i); pts.append(f'{cx+r*math.cos(ang):.1f},{cy+r*math.sin(ang):.1f}')
 txt=f'<text x="180" y="95" fill="{t}" font-family="Arial" font-size="48" font-weight="700">System Forge</text>' if word else ''
 return f'<svg xmlns="http://www.w3.org/2000/svg" width="{w}" height="{h}" viewBox="0 0 {w} {h}" role="img"><title>System Forge</title><desc>Hexágono com trilha ascendente</desc>{f"<rect width=\"100%\" height=\"100%\" fill=\"{bg}\"/>" if dark else ""}<polygon points="{" ".join(pts)}" fill="none" stroke="{p}" stroke-width="12"/><path d="M {cx-34} {cy+30} L {cx-5} {cy+2} L {cx+18} {cy+18} L {cx+42} {cy-32}" fill="none" stroke="{a}" stroke-width="12"/><circle cx="{cx+42}" cy="{cy-32}" r="12" fill="{a}"/>{txt}</svg>'
for n,d,w in [('logo-horizontal.svg',0,1),('logo-horizontal-dark.svg',1,1),('logo-mark.svg',0,0),('logo-mark-dark.svg',1,0),('favicon.svg',0,0)]: (VI/n).write_text(svg(bool(d),bool(w)),encoding='utf-8')

def icon(size,dark=False):
 im=Image.new('RGBA',(size,size),(12,17,23,255) if dark else (247,249,252,255)); dr=ImageDraw.Draw(im); c=size/2;r=size*.31; pts=[]
 for i in range(6):
  ang=math.radians(30+60*i);pts.append((c+r*math.cos(ang),c+r*math.sin(ang)))
 dr.line(pts+[pts[0]],fill=(98,181,245,255) if dark else (0,91,150,255),width=max(2,int(size*.05)),joint='curve'); dr.line([(c-r*.5,c+r*.3),(c,c),(c+r*.2,c+r*.2),(c+r*.5,c-r*.4)],fill=(255,184,106,255),width=max(2,int(size*.05))); return im
for s in [16,32,48,64,72,96,128,144,152,180,192,256,384,512,1024]: icon(s).save(VI/f'icon-{s}.png')
icon(256).save(VI/'favicon.ico',format='ICO',sizes=[(16,16),(32,32),(48,48),(64,64),(128,128),(256,256)])
for name,size,dark in [('og-image.png',(1200,630),1),('twitter-card.png',(1200,600),1),('linkedin-card.png',(1200,627),0),('splash-light.png',(1080,1920),0),('splash-dark.png',(1080,1920),1)]:
 im=Image.new('RGB',size,(12,17,23) if dark else (247,249,252)); mark=icon(min(size)//3,bool(dark)).convert('RGB'); im.paste(mark,((size[0]-mark.width)//2,int(size[1]*.2))); im.save(VI/name)

