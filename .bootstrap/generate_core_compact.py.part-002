(THEME/'web.css').write_text(':root{--sf-primary:#005b96;--sf-secondary:#006c67;--sf-tertiary:#8b4a00;--sf-bg:#f7f9fc;--sf-surface:#fff;--sf-text:#18202a;font-family:Inter,"Segoe UI",sans-serif}[data-theme="dark"]{--sf-primary:#62b5f5;--sf-secondary:#5fd6ce;--sf-tertiary:#ffb86a;--sf-bg:#0c1117;--sf-surface:#151c24;--sf-text:#e3e8ef}:focus-visible{outline:2px solid var(--sf-primary);outline-offset:2px}@media(prefers-reduced-motion:reduce){*{animation-duration:.001ms!important;transition-duration:.001ms!important}}',encoding='utf-8')
