# i18n data
translations={'app':{'name':'System Forge Enterprise','tagline':'Da ideia ao sistema governado'},'common':{'search':'Buscar','filter':'Filtrar','save':'Salvar','cancel':'Cancelar','edit':'Editar','delete':'Excluir','loading':'Carregando','retry':'Tentar novamente','noPermission':'Sem permissão','readOnly':'Somente leitura','blocked':'Bloqueado','processingAi':'IA processando'},'screens':{}}
for sid,title,route,module,ptype,auth,perm,entities,fields,states,actions in screens:
    key=sid.replace('-','_')
    translations['screens'][key]={'title':title,'route':route,'module':module,'actions':{a:a.replace('_',' ').capitalize() for a in actions.split(',')},'fields':{f:f.replace('_',' ').capitalize() for f in fields.split(',')}}
(I18N/'pt-br.json').write_text(json.dumps(translations,ensure_ascii=False,indent=2),encoding='utf-8')

# SVG generator
sizes={'mobile':(390,844),'tablet':(768,1024),'desktop':(1440,1024)}
def svg_screen(screen,res):
    sid,title,route,module,ptype,auth,perm,entities,fields,states,actions=screen
    w,h=sizes[res]
    navw=0 if res=='mobile' else (80 if res=='tablet' else 260)
    top=64 if res=='mobile' else 72
    content_x=16+navw; content_w=w-content_x-16
    cols=1 if res=='mobile' else (2 if res=='tablet' else 3)
    gap=16; card_w=(content_w-gap*(cols-1))/cols
    bg='#0C1117'; surface='#151C24'; outline='#303944'; text='#E3E8EF'; muted='#AEB8C3'; primary='#62B5F5'; tertiary='#FFB86A'
    out=[f'<svg xmlns="http://www.w3.org/2000/svg" width="{w}" height="{h}" viewBox="0 0 {w} {h}" role="img" aria-labelledby="title desc">',f'<title id="title">{html.escape(title)} — {res}</title>',f'<desc id="desc">Wireframe de alta fidelidade da tela {html.escape(title)} na resolução {w} por {h}</desc>',f'<rect width="{w}" height="{h}" fill="{bg}"/>']
    if navw:
        out += [f'<rect x="0" y="0" width="{navw}" height="{h}" fill="{surface}"/>',f'<circle cx="{navw/2}" cy="36" r="18" fill="none" stroke="{primary}" stroke-width="3"/>']
        for i in range(6):
            yy=100+i*58; out.append(f'<rect x="{20 if res=="desktop" else 22}" y="{yy}" width="{navw-40 if res=="desktop" else 36}" height="36" rx="18" fill="{outline if i else primary}" opacity="{1 if i else .9}"/>')
    out += [f'<rect x="{navw}" y="0" width="{w-navw}" height="{top}" fill="{surface}"/>',f'<text x="{content_x}" y="{top+44}" fill="{muted}" font-family="Inter,Arial" font-size="12">{html.escape(module)}  /  {html.escape(route)}</text>',f'<text x="{content_x}" y="{top+82}" fill="{text}" font-family="Inter,Arial" font-size="{24 if res=="mobile" else 30}" font-weight="700">{html.escape(title)}</text>',f'<rect x="{content_x}" y="{top+100}" width="{min(180,content_w*.45)}" height="4" rx="2" fill="{tertiary}"/>']
    y=top+130
    # filter/action bar
    out += [f'<rect x="{content_x}" y="{y}" width="{content_w}" height="56" rx="14" fill="{surface}" stroke="{outline}"/>',f'<rect x="{content_x+12}" y="{y+12}" width="{min(240,content_w*.45)}" height="32" rx="16" fill="{outline}"/>',f'<rect x="{content_x+content_w-112}" y="{y+10}" width="100" height="36" rx="18" fill="{primary}"/>']
    y+=76
    for i in range(cols*2):
        col=i%cols; row=i//cols; x=content_x+col*(card_w+gap); yy=y+row*156
        out += [f'<rect x="{x}" y="{yy}" width="{card_w}" height="140" rx="16" fill="{surface}" stroke="{outline}"/>',f'<rect x="{x+16}" y="{yy+18}" width="{card_w*.52}" height="12" rx="6" fill="{primary}" opacity=".85"/>',f'<rect x="{x+16}" y="{yy+48}" width="{card_w-32}" height="8" rx="4" fill="{outline}"/>',f'<rect x="{x+16}" y="{yy+66}" width="{card_w*.74}" height="8" rx="4" fill="{outline}"/>',f'<rect x="{x+16}" y="{yy+103}" width="{min(96,card_w*.32)}" height="24" rx="12" fill="{tertiary}" opacity=".75"/>']
    # bottom nav mobile
    if res=='mobile':
        out += [f'<rect x="0" y="{h-72}" width="{w}" height="72" fill="{surface}"/>']
        for i in range(4): out.append(f'<circle cx="{49+i*97}" cy="{h-39}" r="12" fill="{primary if i==0 else outline}"/>')
    out.append('</svg>')
    return ''.join(out)

for screen in screens:
    sid=screen[0]; slug=re.sub(r'[^a-z0-9]+','-',screen[1].lower()).strip('-')
    for res in sizes:
        p=WF/res/f'{sid}-{slug}.svg'; p.write_text(svg_screen(screen,res),encoding='utf-8'); ET.fromstring(p.read_text(encoding='utf-8'))

# Screen inventory rows
rows=[]
for s in screens:
    sid,title,route,module,ptype,auth,perm,entities,fields,states,actions=s
    slug=re.sub(r'[^a-z0-9]+','-',title.lower()).strip('-')
    rows.append(f'| {sid} | {title} | `{route}` | {module} | {auth} | `{perm}` | {entities} | {fields} | {states} | {actions} | `wireframes/{{mobile,tablet,desktop}}/{sid}-{slug}.svg` |')

