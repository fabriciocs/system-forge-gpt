from pathlib import Path
import json, re, shutil
R=Path.cwd()/'64BD1EFD'; D=R/'docs'; A=D/'dashboard'; S=A/'src'; G=S/'generated'
for p in [S/'components',S/'pages',G,A/'scripts',A/'module',A/'screenshots']: p.mkdir(parents=True,exist_ok=True)

def w(path,text): p=A/path; p.parent.mkdir(parents=True,exist_ok=True); p.write_text(text,encoding='utf-8')

docs=[]
for i in range(6):
 src=D/f'{i:02d}.md'; dst=G/f'{i:02d}.md'; shutil.copy2(src,dst); text=src.read_text(); docs.append({'id':f'{i:02d}','title':text.splitlines()[0].lstrip('# ').strip(),'route':f'/stages/{i:02d}','sections':len(re.findall(r'^## ',text,re.M)),'words':len(text.split())})
json.dump(docs,(G/'index.json').open('w',encoding='utf-8'),ensure_ascii=False,indent=2)

w('package.json',json.dumps({'name':'system-forge-documentation-dashboard','private':True,'version':'1.0.0','type':'module','scripts':{'dev':'vite','typecheck':'tsc --noEmit','build':'vite build','validate:content':'node scripts/validate-content.mjs','capture':'node scripts/capture.mjs','audit:a11y':'node scripts/a11y.mjs'},'dependencies':{'@emotion/react':'^11.14.0','@emotion/styled':'^11.14.0','@mui/icons-material':'^7.3.6','@mui/material':'^7.3.6','react':'^19.2.3','react-dom':'^19.2.3','react-router-dom':'^7.11.0'},'devDependencies':{'@playwright/test':'^1.57.0','@types/react':'^19.2.7','@types/react-dom':'^19.2.3','@vitejs/plugin-react':'^5.1.1','typescript':'^5.9.3','vite':'^7.3.0'}},indent=2))
w('index.html','<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>System Forge Enterprise</title></head><body><div id="root"></div><script type="module" src="/src/main.tsx"></script></body></html>')
w('tsconfig.json',json.dumps({'compilerOptions':{'target':'ES2022','useDefineForClassFields':True,'lib':['ES2022','DOM','DOM.Iterable'],'allowJs':False,'skipLibCheck':True,'esModuleInterop':True,'allowSyntheticDefaultImports':True,'strict':True,'forceConsistentCasingInFileNames':True,'module':'ESNext','moduleResolution':'Bundler','resolveJsonModule':True,'isolatedModules':True,'noEmit':True,'jsx':'react-jsx'},'include':['src'],'exclude':['dist','node_modules']},indent=2))
w('vite.config.ts',"import{defineConfig}from'vite';import react from'@vitejs/plugin-react';export default defineConfig({plugins:[react()],build:{sourcemap:true}});")
w('src/vite-env.d.ts','/// <reference types="vite/client" />\ndeclare module "*.md?raw"{const value:string;export default value;}')
w('src/theme.ts',"import{createTheme}from'@mui/material/styles';export const theme=createTheme({cssVariables:true,palette:{mode:'dark',primary:{main:'#62B5F5'},secondary:{main:'#5FD6CE'},warning:{main:'#FFB86A'},background:{default:'#0C1117',paper:'#151C24'}},shape:{borderRadius:14},typography:{fontFamily:'Inter,Segoe UI,sans-serif',h1:{fontWeight:750},h2:{fontWeight:700},button:{textTransform:'none',fontWeight:700}},components:{MuiButton:{styleOverrides:{root:{minHeight:44,borderRadius:999}}},MuiCard:{styleOverrides:{root:{backgroundImage:'none'}}}}});")
imports='\n'.join(f"import d{x['id']} from './{x['id']}.md?raw';" for x in docs)
items=',\n'.join(f"{{...meta.find(x=>x.id==='{x['id']}')!,content:d{x['id']}}}" for x in docs)
w('src/generated/documents.ts',f"import meta from './index.json';\n{imports}\nexport type Doc={{id:string;title:string;route:string;sections:number;words:number;content:string}};export const documents:Doc[]=[{items}];")
w('src/markdown.tsx','''import{Box,Chip,Paper,Table,TableBody,TableCell,TableContainer,TableHead,TableRow,Typography}from'@mui/material';import type{ReactNode}from'react';
export function Markdown({text}:{text:string}){const lines=text.split(/\r?\n/);const out:ReactNode[]=[];let i=0;while(i<lines.length){const l=lines[i];if(l.startsWith('|')&&lines[i+1]?.startsWith('|---')){const head=l.split('|').slice(1,-1).map(x=>x.trim());i+=2;const rows:string[][]=[];while(lines[i]?.startsWith('|')){rows.push(lines[i].split('|').slice(1,-1).map(x=>x.trim()));i++}out.push(<TableContainer key={i} component={Paper} sx={{my:2,overflowX:'auto'}}><Table size="small"><TableHead><TableRow>{head.map(h=><TableCell key={h}>{h}</TableCell>)}</TableRow></TableHead><TableBody>{rows.map((r,n)=><TableRow key={n}>{r.map((c,j)=><TableCell key={j}>{c}</TableCell>)}</TableRow>)}</TableBody></Table></TableContainer>);continue}if(l.startsWith('```')){const a=[];i++;while(i<lines.length&&!lines[i].startsWith('```'))a.push(lines[i++]);i++;out.push(<Paper component="pre" key={i} sx={{p:2,overflow:'auto',fontSize:12}}>{a.join('\n')}</Paper>);continue}if(/^#{1,6} /.test(l)){const n=l.match(/^#+/)![0].length;const t=l.slice(n+1);out.push(<Typography key={i} component={n===1?'h2':n===2?'h2':'h3'} variant={n===1?'h4':n===2?'h5':'h6'} sx={{mt:n<3?4:3,mb:1}}>{t}</Typography>)}else if(/^[-*] /.test(l))out.push(<Box component="li" key={i} sx={{ml:3,mb:.5}}>{l.slice(2)}</Box>);else if(l.trim())out.push(<Typography key={i} sx={{mb:1.2,lineHeight:1.75}}>{l}</Typography>);i++}return <>{out}</>}
export const StateChip=({label}:{label:string})=><Chip label={label} size="small" variant="outlined"/>;''')
w('src/App.tsx','''import{useMemo,useState}from'react';import{BrowserRouter,Link,useLocation,useParams}from'react-router-dom';import{AppBar,Box,Card,CardContent,Chip,Container,CssBaseline,Drawer,Grid,IconButton,InputAdornment,List,ListItemButton,ListItemText,Stack,TextField,Toolbar,Typography,useMediaQuery}from'@mui/material';import{Menu,Search,Hub,Description,CheckCircle,Warning}from'@mui/icons-material';import{documents}from'./generated/documents';import{Markdown}from'./markdown';
const nav=[['Visão geral','/'],['Busca','/search'],['Cobertura','/coverage'],['Estados','/states'],...documents.map(d=>[`Etapa ${d.id}`,d.route])];
