# Dependencies
**/node_modules/
**/bower_components/

# Package-manager caches
**/.npm/
**/.pnpm-store/
**/.yarn/cache/
**/.yarn/unplugged/
**/.yarn/build-state.yml
**/.yarn/install-state.gz
**/.pnp.*

# Build outputs and framework caches
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/.output/
**/.vite/
**/.cache/
**/.parcel-cache/
**/.turbo/
**/.angular/
**/coverage/
**/.nyc_output/
**/*.tsbuildinfo

# Runtime and diagnostic files
**/*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock

# Local environment and secrets
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template

# Temporary files
**/tmp/
**/temp/
**/.tmp/
*.tmp
*.temp
*.swp
*.swo
*~

# IDE and editor settings
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# Operating-system files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Test and tooling artifacts
**/playwright-report/
**/test-results/
**/.eslintcache
**/.stylelintcache

# Keep root ZIP archives trackable: they trigger the extraction workflow.
